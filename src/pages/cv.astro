---
import { getCollection } from 'astro:content';
import TimeLineElement from '../components/CV/TimeLine.astro';
import { cv_texts as texts } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = await getCollection('experience');
// Sort experience by date if needed, or by some order field?
// For now, assume default order or adds a sort field.
// Actually, glob loader returns them in file order or arbitrary.
// We might need to add dates to the schema to sort, or just rely on file name?
// The current list is effectively ordered in the config.json.
// Let's just render them.
// To match the exact order, I might need to add a "order" or "startDate" field.
// But for now, let's just fetch them.

const education = await getCollection('education');
// changeLanguage("en");
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.profile.title}</div>
  </div>
  <div class="mb-10 text-justify">
    {texts.profile.description}
  </div>
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.education.title}</div>
  </div>
  <div class="time-line-container grid gap-4 mb-10">
    {
      education.map(item => (
        <TimeLineElement title={item.data.title} subtitle={item.data.subtitle} />
      ))
    }
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.experience.title}</div>
  </div>
  <div class="time-line-container mb-10">
    {
      experience.map(item => (
        <TimeLineElement title={item.data.title} subtitle={item.data.subtitle}>
          {item.data.description}
        </TimeLineElement>
      ))
    }
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.certifications.title}</div>
  </div>
  <ul class="list-disc mx-6 mb-10 grid gap-2">
    {texts.certifications.items.map(item => <li>{item}</li>)}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.skills.title}</div>
  </div>
  <ul class="list-disc md:columns-5 columns-2 mx-6 mb-10">
    {texts.skills.items.map(item => <li>{item}</li>)}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">{texts.learning.title}</div>
  </div>
  <ul class="list-disc md:columns-2 columns-1 mx-6 mb-10">
    {texts.learning.items.map(item => <li>{item}</li>)}
  </ul>
</BaseLayout>
