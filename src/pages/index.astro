---
import { getCollection } from 'astro:content';
import LighthouseScore from '../components/ui/LighthouseScore.astro';
import { SITE_CREATOR } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
const home = (await getCollection('home'))[0].data;
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">{home.greeting}</div>
    <div class="text-5xl font-bold"><Fragment set:html={home.intro} /> {SITE_CREATOR}</div>
    <div class="text-3xl py-3 font-bold">{home.role}</div>
    <div class="py-2">
      <span class="text-lg">
        <Fragment set:html={home.description} />
      </span>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/contacts" class="btn btn-primary gap-2" aria-label="Send me a message">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <Fragment set:html={home.message} />
      </a>
      <a
        class="btn btn-outline"
        href="https://www.linkedin.com/in/alessandro-incantalupo"
        target="_blank"
      >
        <Fragment set:html={home.connect} />
      </a>
    </div>

    <!-- Lighthouse Score Celebration -->
    <div class="mt-8">
      <LighthouseScore />
    </div>
  </div>
</BaseLayout>
