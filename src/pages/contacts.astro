---
import EmailClipboard from '../components/EmailClipboard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacts" includeSidebar={true} sideBarActiveItemID="contacts">
  <div class="flex flex-col items-center justify-center mt-10 md:mt-20 lg:mt-32 w-full px-5">
    <div class="w-full max-w-md flex flex-col items-center">
      <div class="mb-4 text-center">
        <h2 class="text-2xl font-bold tracking-tight">Get in touch</h2>
        <p class="text-base-content/70 text-sm mt-1">Copy the email or send a message directly.</p>
      </div>

      <EmailClipboard email="alessandro.incantalupo@gmail.com" />
    </div>
  </div>
</BaseLayout>
