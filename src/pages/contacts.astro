---
import { getCollection } from 'astro:content';
import EmailClipboard from '../components/ui/EmailClipboard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const contacts = (await getCollection('contacts'))[0].data;
---

<BaseLayout
  title="Contacts"
  includeSidebar={true}
  sideBarActiveItemID="contacts"
  showCalSticky={false}
>
  <div class="flex flex-col items-center justify-center mt-10 md:mt-20 lg:mt-32 w-full px-5">
    <div class="w-full max-w-md flex flex-col items-center gap-6">
      <!-- Email -->
      <div class="w-full flex flex-col items-center">
        <div class="mb-4 w-full text-center">
          <h2 class="text-2xl font-bold tracking-tight">{contacts.emailHeading}</h2>
          <p class="text-base-content/70 text-sm mt-1">{contacts.emailSubtitle}</p>
        </div>
        <EmailClipboard email={contacts.email} />
      </div>

      <!-- Divider -->
      <div class="flex items-center w-full gap-3">
        <div class="flex-1 h-px bg-base-300"></div>
        <span class="text-xs text-base-content/80 uppercase tracking-widest">or</span>
        <div class="flex-1 h-px bg-base-300"></div>
      </div>

      <!-- Book a call -->
      <div class="w-full flex flex-col items-center">
        <div class="mb-4 w-full text-center">
          <h3 class="text-lg font-semibold tracking-tight">{contacts.callHeading}</h3>
          <p class="text-base-content/70 text-sm mt-1" set:html={contacts.callSubtitle} />
        </div>
        <button
          id="cal-booking-btn"
          data-cal-link={contacts.calUsername}
          data-cal-namespace="15min"
          data-cal-config='{"layout":"month_view"}'
          class="btn btn-primary gap-2 rounded-md"
          aria-label="Book a call via Cal.com"
        >
          <!-- Calendar icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          {contacts.callBtn}
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
