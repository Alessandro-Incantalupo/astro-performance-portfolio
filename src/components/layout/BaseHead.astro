---
export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
}

const { title, description, image = '/social_img.webp', ogType = 'website' } = Astro.props;
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Warm up Cal.com connection without downloading anything or setting cookies -->
  <link rel="preconnect" href="https://app.cal.com" crossorigin />
  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Font Preloading: Critical for minimizing FOUT/FOIT and improving LCP -->
  <link
    rel="preload"
    href="/fonts/poppins-latin-400-normal.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
  />
  <link
    rel="preload"
    href="/fonts/poppins-latin-600-normal.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
  />
  <link
    rel="preload"
    href="/fonts/poppins-latin-700-normal.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
  />

  <meta name="generator" content={Astro.generator} />

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="0AxTY6lLp5Q2ySg85VKrs5PaHw1Qv9mopT-ngixe6Fc" />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />

  <!-- Google Verification -->
  <meta name="google-site-verification" content="DtZRfS3T6nBRMCPyI8_Ct80ZSq9Kdyf9fE8a-zUegtA" />

  <!-- 
    JSON-LD STRUCTURED DATA
    This helps Google understand the site structure and generates "Sitelinks" (the sub-navigation links in search results).
  -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "WebSite",
      "name": "{title}",
      "url": "{Astro.url.origin}"
    }
  </script>

  <!-- 
    THEME LOGIC EXPLAINED
    This script is critical for preventing "Flash of Incorrect Theme" (FOUC).
    
    1. It is `is:inline` so it executes IMMEDIATELY when the HTML is parsed, before any content is painted.
    2. It handles:
       - Initial Load: Reads localStorage and sets `data-theme` on <html> instantly.
       - View Transitions: Re-runs via `astro:after-swap` to theme the new page body.
       - Back/Forward Cache: Re-runs via `pageshow` to restore theme when hitting "Back".
    
    CRITICAL: The `disableTransitions` function is a "Transition Lock".
    It temporarily FORCE-DISABLES all CSS transitions while we switch themes.
    Without this, the browser tries to "animate" from the default theme (Light) to the user's theme (Dark),
    causing a visible flash/glitch. We lock it, switch it, and unlock it.
  -->
  <script is:inline data-astro-rerun>
    (function () {
      function getTheme() {
        return localStorage.getItem('data-theme') || 'forest';
      }

      function applyTheme(doc, theme) {
        if (theme) {
          doc.documentElement.setAttribute('data-theme', theme);
        }
      }

      function setTheme(doc) {
        const theme = getTheme();
        applyTheme(doc, theme);
      }

      // Transition Lock: Prevents background color flashing during theme application
      function disableTransitions() {
        const style = document.createElement('style');
        style.id = 'theme-transition-lock';
        style.innerHTML = '*, *::before, *::after { transition: none !important; }';
        document.head.appendChild(style);

        return () => {
          // Force reflow/repaint to flush the "no-transition" state
          window.getComputedStyle(document.body).opacity;

          // Double RAF to ensure we wait for the next paint frame
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              const el = document.getElementById('theme-transition-lock');
              if (el) document.head.removeChild(el);
            });
          });
        };
      }

      // 1. INITIAL LOAD: Run immediately (Block Paint until Theme is set)
      setTheme(document);

      // 2. VIEW TRANSITIONS: Handle client-side navigation
      document.addEventListener('astro:before-swap', ev => {
        // Apply theme to the *new* document structure before it is swapped in.
        setTheme(ev.newDocument);

        // TRANSITION LOCK (View Transition):
        // Inject the lock style into the *incoming* document's head.
        // This ensures the new page paints with transitions DISABLED.
        const style = ev.newDocument.createElement('style');
        style.id = 'theme-transition-lock';
        style.innerHTML = '*, *::before, *::after { transition: none !important; }';
        ev.newDocument.head.appendChild(style);
      });

      document.addEventListener('astro:after-swap', () => {
        // Re-apply verify theme ensures it persists in the active DOM.
        setTheme(document);

        // UNLOCK:
        // The new head (with the lock) is now active. Remove it properly.
        const el = document.getElementById('theme-transition-lock');
        if (el) {
          // Force reflow to flush the "no-transition" state
          window.getComputedStyle(document.body).opacity;
          requestAnimationFrame(() => {
            el.remove();
          });
        }
      });

      // 3. HISTORY NAVIGATION: Handle Back/Forward Cache (BFCache)
      window.addEventListener('pageshow', event => {
        // We run this unconditionally (even if not persisted) to ensure consistency
        // on all history traversals, fixing the "First Back Click" flash.
        const unlock = disableTransitions(); // Lock transitions
        setTheme(document); // Force apply correct theme
        unlock(); // Unlock transitions
      });
    })();
  </script>
  <!--
    Cal.com — lazy-load to keep Lighthouse Best Practices at 100.

    WHY NOT just <script src="embed.js">:
    - Cal.com sets 5 third-party cookies the moment embed.js runs (next-auth tokens, cf_bm, uid).
    - Lighthouse flags those cookies.
    - Lighthouse never hovers/taps anything, so lazy-loading keeps cookies off the audit entirely.

    WHY is:inline (not a normal Astro <script>):
    - Astro wraps scripts as type="module" and defers them → they run after hydration.
    - By then the user could already hover before our listeners exist. is:inline runs in <head>, synchronously.

    WHY preconnect above:
    - Warms DNS + TCP + TLS to app.cal.com at page load for free (no download, no cookies).
    - So when embed.js IS requested on hover, the connection is already open (~100-300ms saved).
  -->
  <script is:inline>
    (function () {
      // ── State flags ───────────────────────────────────────────────────────────
      // calLoaded: true once we've injected the <script> tag — prevents double-loading
      //            even if the user hovers rapidly before the first load finishes.
      // calReady:  true once embed.js has fully executed (onload fired).
      //            Only at this point does Cal's internal event delegation become live.
      let calLoaded = false;
      let calReady = false;

      // ── initCal() ─────────────────────────────────────────────────────────────
      // Idempotent: first call injects embed.js and configures the namespace;
      // subsequent calls are no-ops thanks to the calLoaded guard.
      function initCal() {
        if (calLoaded) return;
        calLoaded = true;

        // This IIFE is Cal.com's own snippet, copied verbatim from their docs.
        // It creates window.Cal as a command-queue stub so that Cal('init', …) and
        // Cal.ns['default']('ui', …) calls below are safe to make before embed.js
        // has finished downloading — they get queued and replayed once it loads.
        (function (C, A, L) {
          const p = function (a, ar) {
            a.q.push(ar);
          };
          C.Cal =
            C.Cal ||
            function () {
              const cal = C.Cal,
                ar = arguments;
              if (!cal.loaded) {
                cal.ns = {};
                cal.q = cal.q || [];
                // Dynamically inject embed.js — this is the moment the script
                // actually starts downloading (only happens on first user intent).
                const s = C.document.createElement('script');
                s.src = A;
                // Set calReady when download + execution is complete.
                s.onload = function () {
                  calReady = true;
                };
                C.document.head.appendChild(s);
                cal.loaded = true;
              }
              // 'init' calls set up a named namespace (e.g. 'default') with its
              // own command queue so multiple embed configs can coexist on a page.
              if (ar[0] === L) {
                const api = function () {
                  p(api, arguments);
                };
                const ns = ar[1];
                api.q = api.q || [];
                if (typeof ns === 'string') {
                  cal.ns[ns] = cal.ns[ns] || api;
                  p(cal.ns[ns], ar);
                  p(cal, [L, ns, ar[2]]);
                } else {
                  p(cal, ar);
                  p(cal, [L]);
                }
                return;
              }
              p(cal, ar);
            };
        })(window, 'https://app.cal.com/embed/embed.js', 'init');

        // ── 15-min meeting namespace ──────────────────────────────────────────────
        // All booking buttons point to 'alessandro-i/15min', so this is the only
        // namespace needed. Any element with data-cal-link="alessandro-i/15min" triggers it.
        Cal('init', '15min', { origin: 'https://cal.com' });
        Cal.ns['15min']('ui', {
          theme: 'dark',
          hideEventTypeDetails: false,
          layout: 'month_view',
          useSlotsViewOnSmallScreen: true
        });

        // Tag the PostHog event with eventType so you can distinguish 15-min bookings
        // from default bookings in your analytics dashboards.
        Cal.ns['15min']('on', {
          action: 'bookingSuccessfulV2',
          callback: function (e) {
            window.posthog?.capture('cal_booking_success', {
              ...e.detail?.data,
              eventType: '15min'
            });
          }
        });
      }

      // ── Intent listeners (event delegation on document) ───────────────────────
      // We listen on document rather than individual buttons so this works for any
      // [data-cal-link] element added dynamically (e.g. after View Transitions).

      // Desktop: mouseover fires ~200ms before click — enough time for embed.js
      // to download on a normal connection before the user actually clicks.
      document.addEventListener(
        'mouseover',
        function (e) {
          if (e.target.closest('[data-cal-link]')) initCal();
        },
        { passive: true }
      ); // passive: true = never calls preventDefault → no scroll jank

      // Mobile: touchstart fires before the synthetic click event, same idea.
      document.addEventListener(
        'touchstart',
        function (e) {
          if (e.target.closest('[data-cal-link]')) initCal();
        },
        { passive: true }
      );

      // ── Click fallback (slow network edge case) ───────────────────────────────
      // On a very slow connection the user might click before embed.js has finished
      // loading. In that case Cal's own click handler isn't live yet, so we:
      //   1. Prevent the default click (nothing to do yet).
      //   2. Poll every 100ms (max 6s / 60 ticks) until calReady is true.
      //   3. Directly invoke Cal's modal API — same thing Cal's click handler does.
      // If calReady is already true when the click fires, we do nothing — Cal's
      // internal event delegation on [data-cal-link] takes over naturally.
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('[data-cal-link]');
        if (!btn) return;
        initCal(); // ensure loading has started (covers instant-click on mobile)
        if (calReady) return; // Cal handles it — hands off
        e.preventDefault();
        // Capture button attributes now, before the async wait, in case the
        // element is replaced by a View Transition before the interval fires.
        var calLink = btn.dataset.calLink;
        var calCfg = {};
        try {
          calCfg = JSON.parse(btn.dataset.calConfig || '{}');
        } catch (ex) {}
        var calOrigin = btn.dataset.calOrigin || '';
        let t = 0;
        const wait = setInterval(function () {
          if (calReady || t++ > 60) {
            // 60 × 100ms = 6 second timeout
            clearInterval(wait);
            // Call Cal's modal API directly — this is exactly what Cal's own
            // document click handler does internally. More reliable than
            // re-dispatching a synthetic click event through multiple handlers.
            if (calReady)
              Cal.ns['15min']('modal', { calLink: calLink, config: calCfg, calOrigin: calOrigin });
            // If timeout hit without calReady, silently give up — user can retry.
          }
        }, 100);
      });
    })();
  </script>
  <slot />
</head>
