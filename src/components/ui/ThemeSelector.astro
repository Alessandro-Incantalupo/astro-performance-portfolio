---
import { THEMES } from '../../consts';
---

<div
  title="Change Theme"
  class="dropdown dropdown-end flex justify-end sticky top-0 z-50 theme-selector-comp group"
>
  <div tabindex="0" class="btn gap-1 normal-case btn-ghost">
    <svg
      width="20"
      height="20"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      class="inline-block h-7 w-7 stroke-current md:h-6 md:w-6"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
      ></path>
    </svg>
    <span class="hidden md:inline">Theme</span>
    <svg
      width="12px"
      height="12px"
      class="ml-1 hidden h-5 w-5 fill-current opacity-60 sm:inline-block group-focus-within:rotate-180 transition-transform duration-200 ease-in-out"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 2048 2048"
    >
      <path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"></path>
    </svg>
  </div>
  <div
    class="dropdown-content bg-base-200 text-base-content rounded-t-box rounded-b-box top-px max-h-96 h-[70vh] w-52 overflow-y-auto shadow-2xl mt-16"
  >
    <div class="grid grid-cols-1 gap-3 p-3" tabindex="0">
      {
        THEMES.map((theme: string) => (
          <div
            class="overflow-hidden rounded-lg border-2 border-transparent hover:border-base-content/50 transition-colors"
            data-set-theme={theme}
            data-act-class="!border-base-content"
          >
            <div
              data-theme={theme}
              class="bg-base-100 text-base-content w-full cursor-pointer font-sans"
            >
              <div class="grid grid-cols-5 grid-rows-3">
                <div class="col-span-5 row-span-3 row-start-1 flex gap-1 py-3 px-4">
                  <div class="grow text-sm font-bold">{theme}</div>
                  <div class="flex shrink-0 flex-wrap gap-1">
                    <div class="bg-primary w-2 rounded" />
                    <div class="bg-secondary w-2 rounded" />
                    <div class="bg-accent w-2 rounded" />
                    <div class="bg-neutral w-2 rounded" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  // Astro uses View Transitions, meaning the page content is swapped without a full reload.
  // We need to re-initialize our event listeners every time a new page is loaded.
  document.addEventListener('astro:page-load', () => {
    initThemeSelectors();
  });

  // We also need to run it once on the very first load (or if view transitions are disabled).
  initThemeSelectors();

  function initThemeSelectors() {
    // We use a class selectors instead of ID because this component is used twice (mobile & desktop header).
    // Using ID would select only the first one found, breaking the second one.
    const themeSelectors = document.querySelectorAll('.theme-selector-comp');

    themeSelectors.forEach(selector => {
      // Cast to HTMLElement to satisfy TypeScript when accessing .dataset
      const htmlSelector = selector as HTMLElement;

      // Logic to update the visual state of the selected theme
      const updateVisualState = () => {
        const theme = localStorage.getItem('data-theme') || 'forest';
        const buttons = htmlSelector.querySelectorAll('[data-set-theme]');
        buttons.forEach(btn => {
          const btnEl = btn as HTMLElement;
          const themeValue = btnEl.getAttribute('data-set-theme');
          const actClass = btnEl.getAttribute('data-act-class');
          if (themeValue === theme) {
            btnEl.classList.add(...(actClass?.split(' ') || []));
          } else {
            btnEl.classList.remove(...(actClass?.split(' ') || []));
          }
        });
      };

      // Update on load
      updateVisualState();

      // Listen for click to update state immediately
      const buttons = htmlSelector.querySelectorAll('[data-set-theme]');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const btnEl = btn as HTMLElement;
          const newTheme = btnEl.getAttribute('data-set-theme');
          if (newTheme) {
            // TRANSITION LOCK: Prevent flash/fade when switching themes manually
            const style = document.createElement('style');
            style.innerHTML = '*, *::before, *::after { transition: none !important; }';
            document.head.appendChild(style);

            localStorage.setItem('data-theme', newTheme);
            document.documentElement.setAttribute('data-theme', newTheme);
            updateVisualState();

            // UNLOCK: Flush changes then remove lock
            window.getComputedStyle(document.body).opacity;
            requestAnimationFrame(() => {
              style.remove();
            });
          }
        });
      });

      // Since this function might run multiple times (initial load + nav), we check a flag
      // to prevent adding the same event listeners twice (which would be inefficient and buggy).
      if (htmlSelector.dataset.initialized === 'true') return;
      htmlSelector.dataset.initialized = 'true';

      const trigger = htmlSelector.querySelector('.btn') as HTMLElement | null;
      const content = htmlSelector.querySelector('.dropdown-content') as HTMLElement | null;

      if (trigger && content) {
        // FIX: The DaisyUI dropdown relies on CSS :focus to stay open.
        // By default, clicking the button again just "sustains" the focus, keeping it open.
        // We listen for 'mousedown' (which fires before click/focus logic) to check state.
        trigger.addEventListener('mousedown', e => {
          // If the button is ALREADY focused, it means the menu is currently OPEN.
          if (document.activeElement === trigger) {
            // We manually .blur() (remove focus) to close it via CSS.
            trigger.blur();
            // Prevent the default click behavior which might re-set focus immediately.
            e.preventDefault();
          }
        });
      }
    });
  }
</script>
