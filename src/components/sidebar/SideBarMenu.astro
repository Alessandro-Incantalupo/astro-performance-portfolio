---
import { NAV_ITEMS } from '../../consts';
// SSR (Server-Side Rendering) Active State
// We calculate the active class HERE (at build time) for each page.
// This prevents the "Flash of Unstyled Content" that happens if you use client-side JS.
// The HTML arrives at the browser with the correct class already applied.
const { sideBarActiveItemID } = Astro.props;
---

<ul class="menu grow shrink menu:vertical-md overflow-y-auto w-full">
  {
    NAV_ITEMS.map(item => (
      <li>
        <a
          class:list={[
            'py-3 text-base block w-full',
            { 'bg-base-300': item.id === sideBarActiveItemID }
          ]}
          id={item.id}
          href={item.url}
          data-astro-prefetch="viewport"
        >
          {item.name}
        </a>
      </li>
    ))
  }
</ul>

<script>
  // We need to import the router to manually trigger navigation after we intercept it.
  import { navigate } from 'astro:transitions/client';

  const activeClass = 'bg-base-300';

  function updateActiveLink(path: string | null = null) {
    const currentPath = path || window.location.pathname;
    const menuItems = document.querySelectorAll('#sidebar-menu:vertical a');

    menuItems.forEach(item => {
      const link = item as HTMLAnchorElement;
      link.classList.remove(activeClass);

      const href = link.getAttribute('href');
      // Logic: Exact match or Subpath match (for nested routes)
      if (href && (href === currentPath || (href !== '/' && currentPath.startsWith(href)))) {
        link.classList.add(activeClass);
      }
      // Explicit Home Check
      if (href === '/' && currentPath === '/') {
        link.classList.add(activeClass);
      }
    });
  }

  // 1. CLICK HANDLER: THE "OPTIMISTIC UI" STRATEGY
  document.addEventListener('DOMContentLoaded', () => {
    // Select by class
    const menu = document.querySelector('.sidebar-nav-list');
    if (menu) {
      menu.addEventListener('click', e => {
        const target = e.target as HTMLElement;
        const link = target.closest('a');
        if (link && menu.contains(link)) {
          e.preventDefault(); // Stop Astro/Browser from handling it yet
          const href = link.getAttribute('href');
          if (href) {
            // 1. Optimistic UI Update (Instant)
            updateActiveLink(href);

            // 2. Trigger Navigation Manually
            navigate(href);
          }
        }
      });
    }
  });

  // 2. Handle Back/Forward Button (State Correction)
  document.addEventListener('astro:page-load', () => {
    updateActiveLink(null);
  });
</script>
