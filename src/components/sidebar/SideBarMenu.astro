<script>
  const activeClass = 'bg-base-300';
  const menuWithActiveItem = document.querySelector('ul[data-active-item]');
  if (menuWithActiveItem) {
    const activeItemID = (menuWithActiveItem as HTMLElement).dataset.activeItem;
    const activeItemElem = document.getElementById(activeItemID!);
    activeItemElem && activeItemElem.classList.add(activeClass);
  }
</script>
