---
export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
}

const { title, description, image = '/social_img.webp', ogType = 'website' } = Astro.props;
---

<head>
  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!--<meta name="viewport" content="width=device-width,initial-scale=1"/>-->
  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <meta name="generator" content={Astro.generator} />

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="0AxTY6lLp5Q2ySg85VKrs5PaHw1Qv9mopT-ngixe6Fc" />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, Astro.url)} />

  <script is:inline data-astro-rerun>
    // ☝️ This script is inline to avoid FOUC (Flash of Unstyled Content).
    // The `data-astro-rerun` attribute ensures it runs on every page transition.
    (function () {
      function getTheme() {
        return localStorage.getItem('data-theme') || 'forest';
      }

      function saveTheme(theme) {
        localStorage.setItem('data-theme', theme);
      }

      function applyTheme(doc, theme) {
        if (theme) {
          doc.documentElement.setAttribute('data-theme', theme);
        }
      }

      function setTheme(doc) {
        const theme = getTheme();
        applyTheme(doc, theme);
      }

      // Expose debug tool to window
      window.getThemeDebug = () => {
        return {
          localStorage: getTheme(),
          htmlAttribute: document.documentElement.getAttribute('data-theme'),
          isMatch: getTheme() === document.documentElement.getAttribute('data-theme')
        };
      };

      // 1. Always set the theme immediately when the script runs (initial load & transitions)
      setTheme(document);

      // 2. Event Listeners Setup (Run once per session ideally, but we check flag)
      if (window.__THEME_INIT__) {
        return; // Listeners already attached, we just needed to run setTheme above.
      }
      window.__THEME_INIT__ = true;

      function changeThemeBehavior(doc) {
        const theme_selectors = doc.querySelectorAll('.theme-selector-comp div[data-theme]');
        theme_selectors.forEach(selector => {
          selector.addEventListener('click', () => {
            const newTheme = selector.getAttribute('data-theme');
            applyTheme(doc, newTheme);
            saveTheme(newTheme);
          });
        });
      }

      // Attach listeners on load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => changeThemeBehavior(document));
      } else {
        changeThemeBehavior(document);
      }

      // 3. Handle View Transitions (Client Router)
      document.addEventListener('astro:before-swap', ev => {
        // CRITICAL: Apply theme to the *new* document structure before it is swapped in.
        // This prevents the "Flash of Default/Wrong Theme" on standard navigation.
        setTheme(ev.newDocument);
      });

      document.addEventListener('astro:after-swap', () => {
        // Re-apply theme to ensure it persists in the active DOM.
        setTheme(document);
        // Re-attach listeners to new DOM elements
        changeThemeBehavior(document);
      });

      // 4. Handle BFCache (History Navigation) using pageshow
      // This event fires when a page is restored from the back-forward cache.
      window.addEventListener('pageshow', event => {
        if (event.persisted) {
          // Page was restored from cache, force theme re-application immediately.
          setTheme(document);
        }
      });

      // 5. Ensure theme is consistent on page load
      document.addEventListener('astro:page-load', () => {
        setTheme(document);
        // Backup: Run again shortly after just in case of race condition with other scripts
        setTimeout(() => setTheme(document), 50);
      });
    })();
  </script>
</head>
