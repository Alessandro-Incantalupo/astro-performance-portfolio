---
interface Props {
  email: string;
}

const { email } = Astro.props;
// Use slice or substring to avoid deprecated substr
const uniqueId = `email-${Math.random().toString(36).slice(2, 11)}`;
---

<div
  class="clipboard-component flex items-center gap-2 p-1.5 border border-base-300 rounded-md bg-base-200/50 shadow-sm transition-all hover:bg-base-200 hover:border-base-content/20 w-fit max-w-full"
  data-unique-id={uniqueId}
>
  <div
    class="px-3 py-2 text-sm font-mono select-all overflow-x-auto whitespace-nowrap min-w-0"
    id={`text-${uniqueId}`}
  >
    {email}
  </div>

  <div class="flex items-center gap-1 pr-1 shrink-0">
    <!-- Copy Button -->
    <button
      id={`copy-btn-${uniqueId}`}
      class="btn btn-ghost btn-sm btn-square h-8 w-8 rounded-md text-base-content/70 hover:text-base-content hover:bg-base-300/50"
      aria-label="Copy email address"
    >
      <span class="default-icon">
        <!-- Lucide Copy Icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-copy"
          ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path
            d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg
        >
      </span>
      <span class="success-icon hidden">
        <!-- Lucide Check Icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-check text-success"><path d="M20 6 9 17l-5-5"></path></svg
        >
      </span>
    </button>

    <!-- Divider -->
    <div class="h-4 w-[1px] bg-base-300 mx-1"></div>

    <!-- Mail Button -->
    <a
      href={`mailto:${email}`}
      class="btn btn-ghost btn-sm btn-square h-8 w-8 rounded-md text-base-content/70 hover:text-base-content hover:bg-base-300/50"
      aria-label="Send email"
    >
      <!-- Lucide Mail Icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-mail"
        ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
          d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
      >
    </a>
  </div>
</div>

<script>
  function initClipboardComponents() {
    document.querySelectorAll('.clipboard-component').forEach(component => {
      // Cast to HTMLElement to access dataset
      const el = component as HTMLElement;
      if (el.dataset.initialized) return;

      const uniqueId = el.dataset.uniqueId;
      const copyBtn = document.getElementById(`copy-btn-${uniqueId}`);
      const textElement = document.getElementById(`text-${uniqueId}`);

      if (copyBtn && textElement) {
        const defaultIcon = copyBtn.querySelector('.default-icon');
        const successIcon = copyBtn.querySelector('.success-icon');

        copyBtn.addEventListener('click', async () => {
          const textToCopy = textElement.innerText;

          if (navigator.clipboard) {
            try {
              await navigator.clipboard.writeText(textToCopy);
              showSuccess(defaultIcon as HTMLElement, successIcon as HTMLElement);
            } catch (err) {
              console.error('Clipboard write failed', err);
            }
          } else {
            console.warn('Clipboard API not supported');
          }
        });
      }

      el.dataset.initialized = 'true';
    });
  }

  function showSuccess(defaultIcon: HTMLElement | null, successIcon: HTMLElement | null) {
    if (defaultIcon && successIcon) {
      defaultIcon.classList.add('hidden');
      successIcon.classList.remove('hidden');

      setTimeout(() => {
        defaultIcon.classList.remove('hidden');
        successIcon.classList.add('hidden');
      }, 5000);
    }
  }

  // Run on initial load
  initClipboardComponents();

  // Run on view transitions navigation
  document.addEventListener('astro:page-load', initClipboardComponents);
</script>
