---
import { ClientRouter } from 'astro:transitions';
import CookieBanner from '../components/analytics/CookieBanner.astro';
import PostHog from '../components/analytics/PostHog.astro';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import SideBar from '../components/sidebar/SideBar.astro';
import '../styles/global.css';

import BaseHead from '../components/layout/BaseHead.astro';
import { GITHUB_URL, SITE_CREATOR, SITE_DESCRIPTION, SITE_TITLE, TRANSITION_API } from '../consts';

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
  showCalSticky = true
} = Astro.props;
---

<html lang="en" class="min-h-screen justify-between">
  <BaseHead title={title} description={description} image={image} , ogType={ogType}>
    <PostHog />
    {TRANSITION_API && <ClientRouter />}
  </BaseHead>
  <body class="flex flex-col min-h-screen justify-between">
    <Header title={SITE_CREATOR} />
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div
        class="drawer-content bg-base-100 flex flex-col justify-between align-middle min-h-screen"
      >
        <div class="md:flex md:flex-col md:items-center justify-between grow w-full">
          <main class="p-6 pt-10 lg:max-w-225 max-w-[100vw] grow w-full">
            <slot />
          </main>
        </div>
        <Footer gitHubUrl={GITHUB_URL} siteCreator={SITE_CREATOR} />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
    {
      showCalSticky && (
        <>
          <button
            id="cal-sticky-btn"
            data-cal-link="alessandro-i/15min"
            data-cal-namespace="15min"
            data-cal-config='{"layout":"month_view"}'
            class="hidden sm:flex fixed bottom-6 right-6 z-50 btn btn-primary shadow-lg gap-2"
            aria-label="Book a call"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span>Book a call</span>
          </button>
        </>
      )
    }
    <CookieBanner />
  </body>
</html>
